# ============================================================
# LERNEN.DE — Variables d'environnement
# ============================================================
# En local : créer un fichier .env.local avec ces variables
# En prod : configurer dans le dashboard Vercel

# ---- DeepSeek API ----
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-v4-flash

# ---- Supabase ----
# Trouver ces valeurs : https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxx

# ⚠️ La SERVICE_ROLE_KEY est ULTRA SENSIBLE :
# - Ne JAMAIS l'exposer au frontend
# - Ne JAMAIS la commit dans Git
# - Seul le backend (Vercel) doit y avoir accès

# ---- Rate limiting & sécurité ----
RATE_LIMIT_PER_HOUR=50
ALLOWED_ORIGIN=*
